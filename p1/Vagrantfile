unless Vagrant.has_plugin?("vagrant-vbguest")
  installed = system("vagrant plugin install vagrant-vbguest")
  warn("Could not auto-install plugin vagrant-vbguest. Install manually if needed.") unless installed
end

class NodeConfig
  attr_reader :name, :ip, :provision_script

  def initialize(name:, ip:, provision_script:)
    @name = name
    @ip = ip
    @provision_script = provision_script
  end
end

NODES = [
  NodeConfig.new(name: "phenriq2S", ip: "192.168.56.110", provision_script: "scripts/server.sh"),
  NodeConfig.new(name: "phenriq2SW", ip: "192.168.56.111", provision_script: "scripts/worker.sh")
].freeze

Vagrant.configure("2") do |config|
  ENV["VAGRANT_DEFAULT_PROVIDER"] = "virtualbox"

  config.vm.box = "bento/debian-13.1"
  config.vm.box_version = "202510.26.0"
  config.vm.boot_timeout = 600

  NODES.each do |node|
    config.vm.define node.name do |machine|
      machine.vm.hostname = node.name
      machine.vm.network "private_network", ip: node.ip
      machine.vm.synced_folder ".", "/vagrant", disabled: false

      machine.vm.provider "virtualbox" do |v|
        v.memory = 2048
        v.cpus = 2
      end

      if node.name == "phenriq2SW"
        machine.vbguest.auto_update = false
      end

      machine.vm.provision "shell", path: node.provision_script
    end
  end
end
